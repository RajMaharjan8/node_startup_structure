// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum OtpPurpose {
  EMAIL_VERIFICATION
  FORGOT_PASSWORD
}
enum UserRoles {
  ADMIN
  CUSTOMER
}

model User{
  id Int @id @default(autoincrement())
  first_name String
  last_name String
  email String @unique
  phone String @unique
  password String
  address String?
  dob String?
  has_email_verified Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  role UserRoles @default(CUSTOMER)
  
  otps Otp[]
}

model Otp{
  id Int @id @default(autoincrement())

  user_id Int 
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  code String
  purpose OtpPurpose
  is_used Boolean @default(false)

  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
}

model Media{
  id Int @id @default(autoincrement())
  name String
  alt String?
  url String
  thumbnail_url String?
  mime_type String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

}


model Package {
  id Int @id @default(autoincrement())
  name String
  description String?

  items PackageItem[]

}

model Item {
  id Int @id @default(autoincrement())
  name String
  price Float
  description String?
  has_stock Boolean @default(true)
  
  thumbnail_id Int?

  packages PackageItem[]
}

model PackageItem{
  package_id Int
  item_id Int

  package Package @relation(fields: [package_id], references: [id], onDelete: Cascade)
  item Item @relation(fields:[item_id], references: [id], onDelete: Cascade )

  @@id([package_id, item_id])
}