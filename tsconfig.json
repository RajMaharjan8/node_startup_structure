{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src", "server.ts", "app.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "generated"]
}
